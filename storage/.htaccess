# Defense-in-depth for the upload directory.
# upload_gallery.php validates MIME and re-encodes to JPEG, so a malicious
# .php disguised as an image shouldn't land here in the first place.
# This rule guarantees that if one ever does, Apache won't execute it.

# Refuse to serve script-like extensions (Apache 2.4+ syntax).
# Previous version also had `php_flag engine off` for belt-and-braces,
# but AGH's AllowOverride doesn't permit it — the whole .htaccess gets
# rejected and Apache returns 500 for every request under storage/.
<FilesMatch "\.(php|phtml|phps|phar|pl|py|cgi|sh|lua|rb)$">
    Require all denied
</FilesMatch>
